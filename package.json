{
  "name": "ict",
  "version": "0.1.0",
  "private": "false",
  "scripts": {
    "turbo1": "NODE_OPTIONS=--dns-result-order=ipv4first next dev --turbopack",
    "dev1": "NODE_OPTIONS=--dns-result-order=ipv4first next dev",
    "turbo": "next dev --turbopack",
    "dev": "next dev",
    "dev:proxy": "USE_API_PROXY=true NEXT_PUBLIC_API_URL=/api/proxy API_PROXY_TARGET=https://ictroot.uk/api next dev",
    "dev:https": "next dev --experimental-https --hostname localhost --port 3000",
    "dev:https:proxy": "USE_API_PROXY=true NEXT_PUBLIC_API_URL=/api/proxy API_PROXY_TARGET=https://ictroot.uk/api next dev --experimental-https --hostname localhost --port 3000",
    "build": "next build",
    "build:production": "next build",
    "start": "next start",
    "tunnel:run": "set -a; . ./.env.local; set +a; cloudflared tunnel run --token \"$CLOUDFLARED_TUNNEL_TOKEN\" --url http://localhost:3000 \"${CLOUDFLARED_TUNNEL_ID:-$CLOUDFLARED_TUNNEL_NAME}\"",
    "tunnel:quick": "cloudflared tunnel --url http://localhost:3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "type-check": "pnpm run typecheck",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3",
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/roboto": "^5.2.6",
    "@hookform/resolvers": "^5.1.1",
    "@ictroot/ui-kit": "2.0.0-beta.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@reduxjs/toolkit": "2.7.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "async-mutex": "^0.5.0",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "eslint-config-next": "15.3.1",
    "eslint-plugin-perfectionist": "2.5.0",
    "file-type": "^21.0.0",
    "framer-motion": "^12.19.2",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "jwt-decode": "^4.0.0",
    "next": "^15.4.4",
    "next-intl": "^4.8.3",
    "react": "^19.0.0",
    "react-advanced-cropper": "^0.20.1",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.0",
    "react-hook-form": "7.56.1",
    "react-i18next": "^15.6.1",
    "react-image-filters": "^0.5.1",
    "react-redux": "^9.2.0",
    "react-toastify": "^11.0.5",
    "uuid": "^13.0.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@it-incubator/eslint-config": "^1.0.4",
    "@it-incubator/prettier-config": "^0.1.2",
    "@it-incubator/stylelint-config": "^2.0.0",
    "@next/bundle-analyzer": "^16.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react-google-recaptcha": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.56.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-pnpm": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "29.0.1",
    "msw": "^2.12.11",
    "prettier": "3.5.3",
    "sass": "^1.87.0",
    "stylelint": "^17.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
