# Public frontend API endpoint
# In local dev, use same-origin proxy to avoid CORS/mobile tunnel issues.
# Example: /api/proxy
NEXT_PUBLIC_API_URL=

# Proxy target used by next.config.ts rewrites when NEXT_PUBLIC_API_URL starts with "/"
# Example: https://ictroot.uk/api
API_PROXY_TARGET=

# Internal origin for server-side fetch when NEXT_PUBLIC_API_URL is relative
# Example: http://localhost:3000
INTERNAL_APP_ORIGIN=

# Public support/contact email shown in UI
NEXT_PUBLIC_CONTACT_EMAIL=

# Public repository URL used in UI links
NEXT_PUBLIC_GITHUB_REPO=

# Public reCAPTCHA site key (not secret)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Base URL for full-check runners (Playwright + Lighthouse)
# Example: http://127.0.0.1:3000
APP_BASE_URL=

# Route used in perf-check as profile sample
# Example: /profile/1
PERF_BUDGET_PROFILE_ROUTE=
